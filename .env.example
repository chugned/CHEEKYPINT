# CheekyPint environment template. Copy to `.env` (git-ignored) and fill in.
# NEVER commit real secrets. The iOS app reads only the non-secret anon key + URL via xcconfig.

# ---- Supabase (backend / tooling) ----
SUPABASE_URL=https://YOUR-REF.supabase.co
SUPABASE_ANON_KEY=your-anon-key                 # non-secret (RLS protects data)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key # SECRET — Edge Functions only, never in the app
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ---- Sign in with Apple (Supabase Auth external provider) ----
APPLE_CLIENT_ID=app.cheekypint.CheekyPint       # Services ID
APPLE_SECRET=your-generated-apple-client-secret # SECRET (JWT signed with your Apple key)

# ---- Edge Function (delete-account) runtime env ----
# Set via `supabase secrets set` — do not hardcode:
#   SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY

# ---- iOS app ----
# The app does NOT read this file. Put SUPABASE_URL + SUPABASE_ANON_KEY into the matching xcconfig:
#   CheekyPint/Resources/Config/{Development,Staging,Production}.xcconfig
